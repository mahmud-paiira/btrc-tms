# ── Django ────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ────────────────────────────────────────────────────────────
DB_NAME=brtc_tms
DB_USER=postgres
DB_PASSWORD=root
DB_HOST=localhost
